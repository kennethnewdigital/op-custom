---
import Layout from "../layouts/Layout.astro";
import { lessons } from "../data/products";
import { Award, Video, ClipboardList, Users, Radar, ArrowRight, User } from "lucide-astro";

const benefits = [
  {
    icon: "award",
    title: "PGA-certifierad",
    desc: "Nico Agnoletto är utbildad och certifierad PGA-instruktör med internationell erfarenhet.",
  },
  {
    icon: "video",
    title: "Videoanalys",
    desc: "Modern videoanalys med slow motion för att identifiera och korrigera dina svagpunkter.",
  },
  {
    icon: "radar",
    title: "TrackMan",
    desc: "Alla lektioner inkluderar TrackMan-analys för exakt data på bollbana, klubbhastighet och spin.",
  },
  {
    icon: "clipboard",
    title: "Personlig plan",
    desc: "Varje elev får en skräddarsydd övningsplan att ta med sig hem efter lektionen.",
  },
  {
    icon: "users",
    title: "Alla nivåer",
    desc: "Från nybörjare till tävlingsspelare — undervisningen anpassas helt efter dig.",
  },
];
---

<Layout title="Golfträning" description="Professionell golfträning med PGA-instruktör Nico Agnoletto. Privatlektioner, kurser och on-course lektioner i Sverige.">

  <!-- Hero -->
  <section class="relative bg-brand-black text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-brand-black via-brand-black/80 to-transparent z-10"></div>
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1535131749006-b7f58c99034b?w=1920&h=1080&fit=crop')] bg-cover bg-center opacity-30"></div>
    <div class="relative z-20 max-w-[1430px] mx-auto px-6 py-28 md:py-40">
      <div class="max-w-2xl">
        <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4">Golfträning</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black uppercase leading-[0.95] mb-6">
          Lyft ditt<br/>spel med <span class="text-brand-red">Nico</span>
        </h1>
        <p class="text-lg text-white/70 max-w-lg leading-relaxed">
          Professionell golfträning med PGA-instruktör Nico Agnoletto. Oavsett om du är nybörjare eller erfaren spelare — vi tar ditt spel till nästa nivå.
        </p>
        <div class="flex flex-wrap gap-4 mt-8">
          <a href="/tidsbokning" class="inline-flex items-center gap-2 px-8 py-4 bg-brand-red text-white text-sm font-bold uppercase tracking-wider rounded-full hover:bg-brand-red-dark transition-colors">
            Boka tid
            <ArrowRight class="w-4 h-4" />
          </a>
          <a href="/nico-agnoletto" class="inline-flex items-center gap-2 px-8 py-4 border-2 border-white/30 text-white text-sm font-bold uppercase tracking-wider rounded-full hover:border-white transition-colors">
            Om Nico
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-[1430px] mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-3">Varför OP Custom</p>
        <h2 class="text-3xl md:text-4xl font-black uppercase">Professionell träning</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8">
        {benefits.map((b) => (
          <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-4 bg-brand-red/10 rounded-xl flex items-center justify-center text-brand-red">
              {b.icon === "award" && <Award class="w-6 h-6" />}
              {b.icon === "video" && <Video class="w-6 h-6" />}
              {b.icon === "radar" && <Radar class="w-6 h-6" />}
              {b.icon === "clipboard" && <ClipboardList class="w-6 h-6" />}
              {b.icon === "users" && <Users class="w-6 h-6" />}
            </div>
            <h3 class="text-sm font-black uppercase tracking-wider mb-3">{b.title}</h3>
            <p class="text-sm text-brand-grey-500 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Instructor Spotlight -->
  <section class="py-20 md:py-28 bg-brand-grey-50">
    <div class="max-w-[1430px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="aspect-[4/5] bg-brand-grey-200 rounded-2xl overflow-hidden">
            <div class="w-full h-full flex items-center justify-center bg-brand-grey-300">
              <div class="text-center">
                <User class="w-24 h-24 mx-auto text-brand-grey-400" strokeWidth={1} />
                <p class="text-brand-grey-400 text-sm mt-2">Foto kommer</p>
              </div>
            </div>
          </div>
        </div>
        <div>
          <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4">Din instruktör</p>
          <h2 class="text-3xl md:text-4xl font-black uppercase mb-6">Nico Agnoletto</h2>
          <p class="text-lg font-semibold text-brand-grey-700 mb-4">PGA-certifierad golfinstruktör</p>
          <p class="text-brand-grey-500 leading-relaxed mb-4">
            Med passion för golf och pedagogik hjälper Nico dig att utveckla ditt spel oavsett var du befinner dig. Hans filosofi bygger på att varje spelare är unik och att träningen ska vara rolig, effektiv och resultatdriven.
          </p>
          <p class="text-brand-grey-500 leading-relaxed mb-4">
            Alla lektioner sker med stöd av <strong class="text-brand-black">TrackMan</strong> — världsledande launch monitor som ger exakt data på klubbhastighet, bollbana, spin och smashfaktor. Perfekt för att mäta och följa dina framsteg.
          </p>
          <p class="text-brand-grey-500 leading-relaxed mb-8">
            Nico har erfarenhet av att träna spelare på alla nivåer — från de som aldrig hållit i en klubba till tävlingsspelare med lågt handikapp.
          </p>
          <a href="/nico-agnoletto" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-brand-red hover:text-brand-red-dark transition-colors">
            Läs mer om Nico
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services / Pricing -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-[1430px] mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-3">Lektioner</p>
        <h2 class="text-3xl md:text-4xl font-black uppercase">Välj din träning</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {lessons.map((s) => (
          <div class:list={[
            "relative bg-brand-grey-50 border rounded-xl p-8 transition-all duration-300 hover:shadow-lg flex flex-col",
            s.popular ? "border-brand-red shadow-md" : "border-brand-grey-200 hover:border-brand-red",
          ]}>
            {s.popular && (
              <span class="absolute -top-3 right-6 bg-brand-red text-white text-[10px] font-bold px-4 py-1 rounded-full uppercase tracking-wider">
                Populärast
              </span>
            )}
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="text-lg font-black uppercase tracking-wide">{s.title}</h3>
                <p class="text-xs text-brand-grey-400 uppercase tracking-wider mt-1">{s.duration}</p>
              </div>
              <span class="text-lg font-black text-brand-red whitespace-nowrap">{s.price}</span>
            </div>
            <p class="text-sm text-brand-grey-500 leading-relaxed mb-6">{s.desc}</p>
            <div class="mt-auto flex gap-2">
              <button
                class="stripe-buy-btn flex-1 py-3 bg-brand-red text-white text-xs font-bold uppercase tracking-wider rounded-full hover:bg-brand-red-dark transition-colors"
                data-price-id={s.stripePriceId}
                data-product-name={s.title}
              >
                Köp & Boka
              </button>
              <a href="/tidsbokning" class="flex-1 py-3 text-center text-xs font-bold uppercase tracking-wider border-2 border-brand-black text-brand-black rounded-full hover:bg-brand-black hover:text-white transition-colors">
                Boka tid
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28 bg-brand-black text-white">
    <div class="max-w-[1430px] mx-auto px-6 text-center">
      <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4">Redo att börja?</p>
      <h2 class="text-3xl md:text-4xl font-black uppercase mb-6">Boka din lektion idag</h2>
      <p class="text-white/60 max-w-lg mx-auto mb-8">
        Välj en tid som passar dig och ta första steget mot ett bättre golfspel.
      </p>
      <a href="/tidsbokning" class="inline-flex items-center gap-2 px-10 py-4 bg-brand-red text-white text-sm font-bold uppercase tracking-wider rounded-full hover:bg-brand-red-dark transition-colors">
        Boka tid nu
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

</Layout>

<script>
  const STRIPE_PUBLISHABLE_KEY = 'pk_test_XXXXX'; // TODO: Add real key

  document.querySelectorAll('.stripe-buy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const priceId = (btn as HTMLElement).dataset.priceId;
      const productName = (btn as HTMLElement).dataset.productName;

      if (!priceId || priceId === 'price_XXXXX') {
        alert(`Betalning via Stripe kommer snart!\n\nLektion: ${productName}\n\nKontakta oss på hello@op-custom.com för att boka och betala.`);
        return;
      }

      try {
        const stripe = (window as any).Stripe?.(STRIPE_PUBLISHABLE_KEY);
        if (stripe) {
          await stripe.redirectToCheckout({
            lineItems: [{ price: priceId, quantity: 1 }],
            mode: 'payment',
            successUrl: `${window.location.origin}/tack`,
            cancelUrl: window.location.href,
          });
        }
      } catch (err) {
        alert('Något gick fel. Kontakta oss på hello@op-custom.com.');
      }
    });
  });
</script>
