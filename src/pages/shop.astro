---
import Layout from "../layouts/Layout.astro";
import { products } from "../data/products";
---

<Layout title="Shop" description="Premium golfutrustning – Scotty Cameron, TaylorMade & mer. Fri frakt över 1000 kr.">

  <!-- Page Header -->
  <section class="bg-brand-black text-white py-20 md:py-28">
    <div class="max-w-[1430px] mx-auto px-6 text-center">
      <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-3">Premium Utrustning</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black uppercase">Shop</h1>
      <p class="text-white/60 mt-4 max-w-lg mx-auto">Utforska vårt sortiment av premium golfutrustning från världens bästa tillverkare.</p>
    </div>
  </section>

  <!-- Filter Bar -->
  <div class="border-b border-brand-grey-200 bg-white sticky top-20 z-30">
    <div class="max-w-[1430px] mx-auto px-6 py-4 flex items-center justify-between">
      <p class="text-sm text-brand-grey-500"><span class="font-bold text-brand-black">{products.length}</span> produkter</p>
      <div class="flex gap-2">
        <button class="filter-btn px-4 py-2 text-xs font-bold uppercase tracking-wider bg-brand-black text-white rounded-full" data-filter="all">Alla</button>
        <button class="filter-btn px-4 py-2 text-xs font-bold uppercase tracking-wider border border-brand-grey-300 text-brand-grey-500 rounded-full hover:border-brand-black hover:text-brand-black transition-colors" data-filter="Putters">Putters</button>
        <button class="filter-btn px-4 py-2 text-xs font-bold uppercase tracking-wider border border-brand-grey-300 text-brand-grey-500 rounded-full hover:border-brand-black hover:text-brand-black transition-colors" data-filter="Drivers">Drivers</button>
        <button class="filter-btn px-4 py-2 text-xs font-bold uppercase tracking-wider border border-brand-grey-300 text-brand-grey-500 rounded-full hover:border-brand-black hover:text-brand-black transition-colors" data-filter="REA">REA</button>
      </div>
    </div>
  </div>

  <!-- Products Grid -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-[1430px] mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="products-grid">
        {products.map((product) => (
          <a href={`/produkt/${product.slug}`} class="product-card group bg-white rounded-xl overflow-hidden border border-brand-grey-200 hover:shadow-xl transition-all duration-300" data-category={product.category} data-badge={product.badge}>
            <div class="relative aspect-square overflow-hidden bg-brand-grey-100">
              <img
                src={product.image}
                alt={product.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              {product.badge && (
                <span class:list={[
                  "absolute top-3 left-3 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider",
                  product.badge === "REA" ? "bg-brand-red" : "bg-brand-black",
                ]}>
                  {product.badge}
                </span>
              )}
            </div>
            <div class="p-5">
              <p class="text-[10px] font-bold uppercase tracking-widest text-brand-grey-400 mb-2">{product.category}</p>
              <h3 class="text-sm font-bold uppercase tracking-wide leading-snug mb-3">{product.name}</h3>
              <div class="flex items-center gap-3">
                <span class:list={[
                  "font-bold text-lg",
                  product.originalPrice ? "text-brand-red" : "text-brand-black",
                ]}>
                  {product.price}
                </span>
                {product.originalPrice && (
                  <span class="text-brand-grey-400 text-sm line-through">{product.originalPrice}</span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-grey-50 border-t border-brand-grey-200">
    <div class="max-w-[1430px] mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-black uppercase mb-4">Hittar du inte det du söker?</h2>
      <p class="text-brand-grey-500 mb-8 max-w-lg mx-auto">Vi hjälper dig att hitta rätt utrustning. Kontakta oss så berättar vi mer.</p>
      <a href="/kontakt" class="inline-flex items-center px-8 py-4 bg-brand-red text-white text-sm font-bold uppercase tracking-wider rounded-full hover:bg-brand-red-dark transition-colors">
        Kontakta oss
      </a>
    </div>
  </section>

</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const productCards = document.querySelectorAll('.product-card');

  function applyFilter(filter: string) {
    filterBtns.forEach(b => {
      const btnFilter = (b as HTMLElement).dataset.filter;
      if (btnFilter === filter) {
        b.classList.add('bg-brand-black', 'text-white');
        b.classList.remove('border', 'border-brand-grey-300', 'text-brand-grey-500');
      } else {
        b.classList.remove('bg-brand-black', 'text-white');
        b.classList.add('border', 'border-brand-grey-300', 'text-brand-grey-500');
      }
    });

    productCards.forEach((card) => {
      const el = card as HTMLElement;
      const category = el.dataset.category;
      const badge = el.dataset.badge;

      if (filter === 'all') {
        el.style.display = '';
      } else if (filter === 'REA') {
        el.style.display = badge === 'REA' ? '' : 'none';
      } else {
        el.style.display = category === filter ? '' : 'none';
      }
    });
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter || 'all';
      window.location.hash = filter === 'all' ? '' : filter.toLowerCase();
      applyFilter(filter);
    });
  });

  // Apply filter from URL hash on page load
  const hash = window.location.hash.replace('#', '').toLowerCase();
  const hashMap: Record<string, string> = {
    'putters': 'Putters',
    'drivers': 'Drivers',
    'rea': 'REA',
  };
  if (hash && hashMap[hash]) {
    applyFilter(hashMap[hash]);
  }
</script>
