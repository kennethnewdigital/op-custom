---
import Layout from "../layouts/Layout.astro";
import { products } from "../data/products";
import { ChevronRight } from "lucide-astro";

const featuredProducts = products.filter((p) => p.badge === "REA").slice(0, 4);

const categories = [
  { name: "Custom Putters", href: "/custom-putters", desc: "Unika finishar & personlig design", image: "/images/op-costome-scotty-cameron-custom kopiera.webp" },
  { name: "Scotty Cameron", href: "/shop#putters", desc: "Premium putters sedan 1991", image: "/images/moto.webp" },
  { name: "Titleist Logobollar", href: "/titleist-logobollar", desc: "Eget tryck & logotyp", image: "/images/T2029S_01.avif" },
  { name: "Golfträning", href: "/golftraning", desc: "PGA-instruktör & TrackMan", image: "/images/hero_op-custom.webp" },
  { name: "Golfklubbor", href: "/shop#drivers", desc: "Drivers, fairway woods & mer", image: "/images/REA_Qi10_fairway.webp" },
  { name: "Tillbehör", href: "/shop", desc: "Grepp, skaft & tillbehör", image: "/images/golfgrepp.webp" },
  { name: "Boka tid", href: "/tidsbokning", desc: "Boka lektion med Nico", image: "/images/4.jpg" },
  { name: "REA", href: "/shop#rea", desc: "Utvalda produkter till kampanjpris", image: "/images/rea_produkter.webp" },
];
---

<Layout title="Hem" description="OP Custom – Premium golfutrustning och custom putters i Sverige. Scotty Cameron, TaylorMade och Titleist.">

  <!-- Hero Section -->
  <section class="relative bg-brand-black text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-brand-black via-brand-black/70 to-transparent z-10"></div>
    <div class="absolute inset-0">
      <img
        src="/images/hero_op-custom.webp"
        alt="Golfare på driving range"
        class="w-full h-full object-cover object-[30%_center] lg:object-[50%_center]"
      />
    </div>
    <div class="relative z-20 max-w-[1430px] mx-auto px-6 py-32 md:py-44 lg:py-56">
      <div class="max-w-2xl">
        <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-4">Premium Golf Equipment</p>
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-black uppercase leading-[0.95] mb-6">
          Gör din golf<br/>
          <span class="text-brand-red">personlig</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 mb-10 max-w-lg leading-relaxed">
          Custom putters, premium utrustning och Titleist logobollar. Upplev skillnaden med utrustning anpassad efter dig.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/shop" class="inline-flex items-center px-8 py-4 bg-brand-red text-white text-sm font-bold uppercase tracking-wider rounded-full hover:bg-brand-red-dark transition-colors">
            Utforska Shop
          </a>
          <a href="/custom-putters" class="inline-flex items-center px-8 py-4 border-2 border-white text-white text-sm font-bold uppercase tracking-wider rounded-full hover:bg-white hover:text-brand-black transition-colors">
            Custom Putters
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Carousel -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-[1430px] mx-auto px-6">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-3">Kategorier</p>
          <h2 class="text-3xl md:text-4xl font-black uppercase">Utforska</h2>
        </div>
        <div class="hidden sm:flex gap-2">
          <button id="carousel-prev" class="w-10 h-10 rounded-full border border-brand-grey-300 flex items-center justify-center text-brand-grey-400 hover:border-brand-black hover:text-brand-black transition-colors disabled:opacity-30 disabled:cursor-not-allowed" disabled>
            <ChevronRight class="w-5 h-5 rotate-180" />
          </button>
          <button id="carousel-next" class="w-10 h-10 rounded-full border border-brand-grey-300 flex items-center justify-center text-brand-grey-400 hover:border-brand-black hover:text-brand-black transition-colors disabled:opacity-30 disabled:cursor-not-allowed">
            <ChevronRight class="w-5 h-5" />
          </button>
        </div>
      </div>
    </div>
    <div
      id="category-carousel"
      class="flex gap-4 overflow-x-auto scroll-smooth snap-x snap-mandatory px-6 pb-4 -mx-0"
      style="scrollbar-width: none; -ms-overflow-style: none;"
    >
      <div class="shrink-0 w-[calc((100%-2rem)/1.2)] sm:w-[calc((100%-3rem)/2.3)] lg:w-[calc((100%-5rem)/3.5)] xl:w-[calc((100%-6rem)/4.2)] snap-start first:ml-[max(1.5rem,calc((100%-1430px)/2+1.5rem))] last:mr-6" style="display:none"></div>
      {categories.map((cat, i) => (
        <a
          href={cat.href}
          class:list={[
            "group relative shrink-0 snap-start rounded-2xl overflow-hidden",
            "w-[calc((100%-2rem)/1.2)] sm:w-[calc((100%-3rem)/2.3)] lg:w-[calc((100%-5rem)/3.5)] xl:w-[calc((100%-6rem)/4.2)]",
            i === 0 ? "ml-[max(1.5rem,calc((100%-1430px)/2+1.5rem))]" : "",
            i === categories.length - 1 ? "mr-6" : "",
          ]}
        >
          <div class="relative aspect-[4/5] overflow-hidden bg-brand-grey-100">
            <img
              src={cat.image}
              alt={cat.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="text-white text-lg font-black uppercase tracking-wide mb-1">{cat.name}</h3>
              <p class="text-white/60 text-sm">{cat.desc}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured Products -->
  <section class="py-20 md:py-28 bg-brand-grey-50">
    <div class="max-w-[1430px] mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-3">Kampanj</p>
        <h2 class="text-3xl md:text-4xl font-black uppercase">Utvalda Produkter</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredProducts.map((product) => (
          <a href={`/produkt/${product.slug}`} class="group bg-white rounded-xl overflow-hidden border border-brand-grey-200 hover:shadow-xl transition-all duration-300">
            <div class="relative aspect-square overflow-hidden bg-brand-grey-100">
              <img
                src={product.image}
                alt={product.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              {product.badge && (
                <span class="absolute top-3 left-3 bg-brand-red text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                  {product.badge}
                </span>
              )}
            </div>
            <div class="p-5">
              <h3 class="text-sm font-bold uppercase tracking-wide leading-snug mb-3">{product.name}</h3>
              <div class="flex items-center gap-3">
                <span class="text-brand-red font-bold text-lg">{product.price}</span>
                {product.originalPrice && (
                  <span class="text-brand-grey-400 text-sm line-through">{product.originalPrice}</span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/shop" class="inline-flex items-center px-8 py-4 bg-brand-black text-white text-sm font-bold uppercase tracking-wider rounded-full hover:bg-brand-grey-800 transition-colors">
          Se alla produkter
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative bg-brand-black text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-brand-red/20 to-transparent"></div>
    <div class="relative max-w-[1430px] mx-auto px-6 py-20 md:py-28">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-3">Custom Finishing</p>
        <h2 class="text-3xl md:text-4xl font-black uppercase mb-6">Skapa din drömputter</h2>
        <p class="text-white/60 text-lg mb-10 leading-relaxed">
          Välj mellan Black Oxide, Copper, Raw och Painted finish. Vi ger din putter ett unikt utseende.
        </p>
        <a href="/custom-putters" class="inline-flex items-center px-8 py-4 bg-brand-red text-white text-sm font-bold uppercase tracking-wider rounded-full hover:bg-brand-red-dark transition-colors">
          Begär offert
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-[1430px] mx-auto px-6">
      <div class="max-w-xl mx-auto text-center">
        <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-3">Nyhetsbrev</p>
        <h2 class="text-3xl md:text-4xl font-black uppercase mb-4">Håll dig uppdaterad</h2>
        <p class="text-brand-grey-500 mb-10">Få nyheter om produkter, erbjudanden och custom-projekt direkt i din inkorg.</p>
        <form class="flex flex-col sm:flex-row gap-3" name="newsletter">
          <input
            type="email"
            name="email"
            placeholder="Din e-postadress"
            required
            class="flex-1 px-5 py-4 border border-brand-grey-300 rounded-full text-sm focus:outline-none focus:border-brand-red transition-colors"
          />
          <button
            type="submit"
            class="px-8 py-4 bg-brand-red text-white text-sm font-bold uppercase tracking-wider rounded-full hover:bg-brand-red-dark transition-colors"
          >
            Prenumerera
          </button>
        </form>
      </div>
    </div>
  </section>

</Layout>

<script>
  const carousel = document.getElementById('category-carousel');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');

  if (carousel && prevBtn && nextBtn) {
    const getScrollAmount = () => {
      const card = carousel.querySelector('a');
      return card ? card.offsetWidth + 16 : 320;
    };

    const updateButtons = () => {
      const { scrollLeft, scrollWidth, clientWidth } = carousel;
      (prevBtn as HTMLButtonElement).disabled = scrollLeft <= 10;
      (nextBtn as HTMLButtonElement).disabled = scrollLeft + clientWidth >= scrollWidth - 10;
    };

    prevBtn.addEventListener('click', () => {
      carousel.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      carousel.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });

    carousel.addEventListener('scroll', updateButtons, { passive: true });
    updateButtons();
  }
</script>

<style>
  #category-carousel::-webkit-scrollbar {
    display: none;
  }
</style>
