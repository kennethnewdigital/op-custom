---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kontakt" description="Kontakta OP Custom – Vi hjälper dig med premium golfutrustning, custom putters och Titleist logobollar.">

  <!-- Hero -->
  <section class="bg-brand-black text-white py-20 md:py-28">
    <div class="max-w-[1430px] mx-auto px-6 text-center">
      <p class="text-brand-red font-bold text-sm tracking-[0.3em] uppercase mb-3">Kontakta Oss</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black uppercase">Hör av dig</h1>
      <p class="text-white/60 mt-4 max-w-lg mx-auto">Vi svarar normalt inom 24 timmar. Tveka inte att kontakta oss med frågor eller önskemål.</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-[1430px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-16">

        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-black uppercase mb-8">Kontaktinfo</h2>

          <div class="space-y-8">
            <div>
              <h3 class="text-xs font-bold uppercase tracking-widest text-brand-grey-400 mb-2">E-post</h3>
              <a href="mailto:hello@op-custom.com" class="text-lg font-semibold hover:text-brand-red transition-colors">
                hello@op-custom.com
              </a>
            </div>

            <div>
              <h3 class="text-xs font-bold uppercase tracking-widest text-brand-grey-400 mb-2">Plats</h3>
              <p class="text-lg font-semibold">Sverige</p>
            </div>

            <div>
              <h3 class="text-xs font-bold uppercase tracking-widest text-brand-grey-400 mb-2">Sociala medier</h3>
              <div class="flex gap-4 mt-2">
                <a href="#" class="w-10 h-10 bg-brand-grey-100 rounded-full flex items-center justify-center text-brand-grey-500 hover:bg-brand-red hover:text-white transition-colors" aria-label="Facebook">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="#" class="w-10 h-10 bg-brand-grey-100 rounded-full flex items-center justify-center text-brand-grey-500 hover:bg-brand-red hover:text-white transition-colors" aria-label="Instagram">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
                <a href="#" class="w-10 h-10 bg-brand-grey-100 rounded-full flex items-center justify-center text-brand-grey-500 hover:bg-brand-red hover:text-white transition-colors" aria-label="YouTube">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>
              </div>
            </div>

            <div class="pt-4 border-t border-brand-grey-200">
              <h3 class="text-xs font-bold uppercase tracking-widest text-brand-grey-400 mb-3">Snabblänk</h3>
              <ul class="space-y-2">
                <li><a href="/custom-putters" class="text-sm font-semibold hover:text-brand-red transition-colors">Custom Putters &rarr;</a></li>
                <li><a href="/titleist-logobollar" class="text-sm font-semibold hover:text-brand-red transition-colors">Titleist Logobollar &rarr;</a></li>
                <li><a href="/shop" class="text-sm font-semibold hover:text-brand-red transition-colors">Shop &rarr;</a></li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <div class="bg-brand-grey-50 border border-brand-grey-200 rounded-2xl p-8 md:p-12">
            <h2 class="text-2xl font-black uppercase mb-2">Skicka ett meddelande</h2>
            <p class="text-brand-grey-500 text-sm mb-8">Fyll i formuläret så återkommer vi så snart som möjligt.</p>

            <form class="space-y-6" name="contact" method="POST">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="c-fname" class="block text-xs font-bold uppercase tracking-wider mb-2">Förnamn *</label>
                  <input type="text" id="c-fname" name="firstname" required
                    class="w-full px-5 py-4 border border-brand-grey-300 rounded-xl text-sm focus:outline-none focus:border-brand-red transition-colors bg-white"
                    placeholder="Förnamn" />
                </div>
                <div>
                  <label for="c-lname" class="block text-xs font-bold uppercase tracking-wider mb-2">Efternamn *</label>
                  <input type="text" id="c-lname" name="lastname" required
                    class="w-full px-5 py-4 border border-brand-grey-300 rounded-xl text-sm focus:outline-none focus:border-brand-red transition-colors bg-white"
                    placeholder="Efternamn" />
                </div>
              </div>

              <div>
                <label for="c-email" class="block text-xs font-bold uppercase tracking-wider mb-2">E-post *</label>
                <input type="email" id="c-email" name="email" required
                  class="w-full px-5 py-4 border border-brand-grey-300 rounded-xl text-sm focus:outline-none focus:border-brand-red transition-colors bg-white"
                  placeholder="din@epost.se" />
              </div>

              <div>
                <label for="c-subject" class="block text-xs font-bold uppercase tracking-wider mb-2">Ämne</label>
                <select id="c-subject" name="subject"
                  class="w-full px-5 py-4 border border-brand-grey-300 rounded-xl text-sm focus:outline-none focus:border-brand-red transition-colors bg-white">
                  <option value="">-- Välj ämne --</option>
                  <option value="custom-putter">Custom Putter</option>
                  <option value="logobollar">Titleist Logobollar</option>
                  <option value="shop">Frågor om produkter</option>
                  <option value="putter-fitting">Putter Fitting</option>
                  <option value="trade-in">Scotty Trade-In</option>
                  <option value="other">Övrigt</option>
                </select>
              </div>

              <div>
                <label for="c-message" class="block text-xs font-bold uppercase tracking-wider mb-2">Meddelande *</label>
                <textarea id="c-message" name="message" rows="6" required
                  class="w-full px-5 py-4 border border-brand-grey-300 rounded-xl text-sm focus:outline-none focus:border-brand-red transition-colors resize-y bg-white"
                  placeholder="Skriv ditt meddelande här..."></textarea>
              </div>

              <button type="submit"
                class="w-full py-4 bg-brand-red text-white text-sm font-bold uppercase tracking-wider rounded-full hover:bg-brand-red-dark transition-colors">
                Skicka meddelande
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
